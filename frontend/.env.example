# CashPilot Frontend — Environment Variables
# Copy this file to .env and fill in your values.

# Backend API base URL (no trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# WebSocket URL for live pipeline events and alerts
VITE_WS_URL=ws://localhost:8000/ws

# API key to authenticate requests (must match backend API_KEY in .env)
# Leave empty to disable auth during local dev
VITE_API_KEY=
