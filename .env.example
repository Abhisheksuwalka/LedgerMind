# ─────────────────────────────────────────────────────────────────────────────
# LedgerMind — Environment Configuration
# Copy this file to .env and fill in at least ONE free LLM key to run.
# ─────────────────────────────────────────────────────────────────────────────

# --- LLM Providers (add at least ONE free key to run) ------------------------
GROQ_API_KEY=gsk_your_key_here        # FREE  — primary provider  (https://console.groq.com/keys)
GEMINI_API_KEY=AIza_your_key_here     # FREE  — secondary fallback (https://aistudio.google.com/apikey)
ANTHROPIC_API_KEY=                    # PAID  — optional, used only for report generation

# LLM model overrides (defaults shown — change only if needed)
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_MODEL=gemini-2.0-flash-exp
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local Ollama (optional — set BASE_URL to activate)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# --- Financial Settings -------------------------------------------------------
TAX_RATE_PCT=25                       # Configurable tax rate for P&L (default 25%)

# --- Database -----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://finagent:finagent_pass@postgres:5432/finagent_db
POSTGRES_USER=finagent
POSTGRES_PASSWORD=finagent_pass
POSTGRES_DB=finagent_db

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- Runtime mode --------------------------------------------------------------
# Set to production to enforce fail-closed auth checks.
ENVIRONMENT=development

# --- Auth ---------------------------------------------------------------------
# Public API auth. In production this must be set.
API_KEY=

# Internal service-to-service auth used by Celery -> FastAPI internal endpoints.
# In production this must be set and must match worker + backend environments.
INTERNAL_API_SECRET=

# URL used by Celery workers to reach backend internal endpoints.
INTERNAL_API_URL=http://backend:8000

# --- Email Notifications (optional — pipeline works without these) -----------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=reports@ledgermind.ai
NOTIFICATION_EMAIL=your@email.com

# --- Frontend (used by Vite dev server) --------------------------------------
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
